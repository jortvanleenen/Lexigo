{
  "devDependencies": {
    "@eslint/compat": "^1.2.7",
    "@eslint/css": "^0.11.0",
    "@eslint/js": "^9.35.0",
    "@floating-ui/core": "1.7.5",
    "@floating-ui/dom": "1.7.6",
    "eslint": "^9.35.0",
    "eslint-config-prettier": "^10.1.0",
    "globals": "^16.4.0",
    "prettier": "3.6.2",
    "web-ext": "^10.4.0"
  },
  "scripts": {
    "dev": "web-ext --config=web-ext.config.mjs run",
    "build": "web-ext --config=web-ext.config.mjs build --overwrite-dest",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "lint:ext": "web-ext --config=web-ext.config.mjs lint",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "prepare": "npm run lint && npm run format && npm run lint:ext"
  }
}
